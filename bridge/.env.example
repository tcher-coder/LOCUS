# LOCUS secrets — скопируйте в .env (корень репо для Docker / bridge/.env для локального запуска)
# и заполните. НИКОГДА не коммитьте заполненный файл.

# Токен Telegram-бота (@BotFather)
BOT_TOKEN=

# Ваш Telegram user id (@userinfobot) — бот отвечает только этому пользователю
OWNER_CHAT_ID=

# OAuth-токен подписки Claude Pro/Max: команда `claude setup-token` (живёт 1 год)
CLAUDE_CODE_OAUTH_TOKEN=

# Ключ Groq для Whisper-фолбэка на видео без субтитров (console.groq.com), опционально
GROQ_API_KEY=

# ID приватного канала-архива (бот — админ), вида -100... Пусто = архив выключен.
ARCHIVE_CHANNEL_ID=

# Таймаут одной задачи агента в минутах (по умолчанию 30)
# TASK_TIMEOUT_MIN=30

# Фаза 2 — обновление вики-памяти (Karpathy LLM-Wiki). По умолчанию выключена.
# WIKI_ENABLED=1
